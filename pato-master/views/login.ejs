<!DOCTYPE html>
<html lang="es">
<head>
    <title>Login - Pato Place</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link rel="stylesheet" type="text/css" href="/vendor/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" type="text/css" href="/fonts/font-awesome-4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" type="text/css" href="/css/util.css">
    <link rel="stylesheet" type="text/css" href="/css/main.css">
    <link rel="stylesheet" type="text/css" href="/css/custom.css">
</head>
<body class="bg-login">

    <header>
        <div class="wrap-menu-header gradient1 trans-0-4">
            <div class="container h-full">
                <div class="wrap_header trans-0-3">
                    <div class="logo">
                        <a href="/"><img src="/images/icons/logo.png" alt="IMG-LOGO"></a>
                    </div>
                    <div class="wrap_menu">
                        <nav class="menu">
                            <ul class="main_menu">
                                <li><a href="/">Inicio</a></li>
                                <li><a href="/menu">Menu</a></li>
                                <li><a href="/register" class="btn-register-nav">Register</a></li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="container">
        <div class="row">
            <div class="col-md-6 col-lg-5 m-l-r-auto">
                <div class="login-container">
                    <div class="t-center p-b-30">
                        <span class="tit2">Ingreso</span>
                        <h3 class="tit3 m-t-5">Pato Place</h3>
                    </div>

                    <form action="/login" method="POST">
                        <div class="m-b-20">
                            <span class="txt9">Usuario</span>
                            <div class="bo2 bo-rad-10 m-t-5">
                                <input class="sizefull txt10 p-l-20 p-t-15 p-b-15 bo-rad-10" type="text" name="user" placeholder="Nombre de usuario" required>
                            </div>
                        </div>

                        <div class="m-b-30">
                            <span class="txt9">Contraseña</span>
                            <div class="bo2 bo-rad-10 m-t-5">
                                <input class="sizefull txt10 p-l-20 p-t-15 p-b-15 bo-rad-10" type="password" name="password" placeholder="********" required>
                            </div>
                        </div>

                        <div class="wrap-btn-booking flex-c-m">
                            <button type="submit" class="btn3 flex-c-m size13 txt11 trans-0-4">
                                Iniciar Sesión
                            </button>
                        </div>
                    </form>

                    <div class="t-center m-t-25">
                        <a href="/register" class="txt11">¿No tienes cuenta? Regístrate aquí</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/vendor/jquery/jquery-3.2.1.min.js"></script>
    <script src="/js/main.js"></script>

</body>
</html>