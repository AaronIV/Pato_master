<!DOCTYPE html>
<html lang="es">
<head>
    <title>Registro - Pato Place</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" type="text/css" href="/vendor/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" type="text/css" href="/fonts/font-awesome-4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" type="text/css" href="/css/util.css">
    <link rel="stylesheet" type="text/css" href="/css/main.css">
</head>
<body class="animsition">

    <section class="section-reservation bg1-pattern p-t-100 p-b-113">
        <div class="container">
            <div class="row">
                <div class="col-lg-6 p-b-30 m-l-r-auto">
                    <div class="t-center p-b-40">
                        <span class="tit2 t-center">Únete a</span>
                        <h3 class="tit3 t-center m-b-35 m-t-5">Pato Place</h3>
                    </div>

                    <form action="/register" method="POST" class="wrap-form-reservation size22 m-l-r-auto">
                        <div class="row">
                            <div class="col-md-12">
                                <span class="txt9">Nombre de Usuario</span>
                                <div class="wrap-inputname size12 bo2 bo-rad-10 m-t-3 m-b-23">
                                    <input class="bo-rad-10 sizefull txt10 p-l-20" type="text" name="user" placeholder="Ej: aaron123" required>
                                </div>

                                <span class="txt9">Contraseña</span>
                                <div class="wrap-inputemail size12 bo2 bo-rad-10 m-t-3 m-b-23">
                                    <input class="bo-rad-10 sizefull txt10 p-l-20" type="password" name="password" placeholder="********" required>
                                </div>
                            </div>
                        </div>

                        <div class="wrap-btn-booking flex-c-m m-t-6">
                            <button type="submit" class="btn3 flex-c-m size13 txt11 trans-0-4">
                                Registrarse
                            </button>
                        </div>

                        <div class="t-center m-t-20">
                            <p class="txt10">¿Ya tienes cuenta? <a class="button" href="/login" class="txt11">Inicia sesión aquí</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <script type="text/javascript" src="/vendor/jquery/jquery-3.2.1.min.js"></script>
    <script type="text/javascript" src="/vendor/animsition/js/animsition.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>